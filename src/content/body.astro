---
import Logo from "@svg/logo.svg";
import Luis from "@img/luis.webp";
import Ting from "@img/ting.webp";
import Groot from "@img/groot.webp";
import Megan from "@img/megan.webp";
import "aos/dist/aos.css"; // AOS styles
---

<!-- Hero Section - Clean monochromatic design -->
<section id="intro" class="wrapper fullscreen bg-gray-950">
  
  <div class="inner">
    <div class="container mx-auto px-4 max-w-7xl">
      <!-- Hero content with logo and headline -->
      <div class="grid md:grid-cols-2 gap-8 items-center mb-16">
        <div
          class="flex justify-center items-center"
          data-aos="fade-right"
          data-aos-duration="800"
        >
          <img
            src={Logo.src}
            class="w-64 h-64 md:w-80 md:h-80"
            alt="skypier logo"
          />
        </div>
        <div class="text-center md:text-left space-y-6">
          <h1
            class="text-5xl md:text-7xl font-bold text-white leading-tight"
            data-aos="fade-left"
            data-aos-duration="800"
          >
            Embark securely on <span class="text-primary-500">web3</span>
          </h1>
          <h2
            class="text-2xl md:text-3xl text-gray-400 font-light"
            data-aos="fade-left"
            data-aos-duration="1000"
          >
            The future of Decentralized Hybrid Cloud and Privacy Stack.
          </h2>
        </div>
      </div>

      <!-- Value proposition card -->
      <div class="bg-gray-900 rounded-xl border border-gray-800 p-8 md:p-12 mb-12" 
           data-aos="fade-up" 
           data-aos-duration="800">
        <p class="text-lg md:text-xl text-gray-300 leading-relaxed mb-8">
          Skypier is the gateway that empowers people to express and explore
          anonymously without compromising their privacy or quality of access. Our
          Token Gated decentralized Network is a subscription based peer-to-peer
          VPN that enables anyone to create their own hybrid cloud.
        </p>
        <div class="flex flex-wrap gap-4 justify-center md:justify-start">
          <a
            href="https://tinglik.notion.site/On-boarding-the-SkyPier-Network-0967d277dfee49dfb2e537a1b89961b6"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-lg transition-colors duration-200"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
            View Demo
          </a>
          <a 
            href="/products" 
            class="inline-flex items-center px-8 py-4 bg-gray-800 hover:bg-gray-700 text-white font-semibold rounded-lg border border-gray-700 transition-colors duration-200"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
            Our Products
          </a>
          <a 
            href="#contact" 
            class="inline-flex items-center px-8 py-4 bg-gray-800 hover:bg-gray-700 text-white font-semibold rounded-lg border border-gray-700 transition-colors duration-200"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            Contact Us
          </a>
        </div>
      </div>

      <!-- Waitlist form -->
      <div class="bg-gray-900 rounded-xl border border-primary-900 p-8 max-w-2xl mx-auto" 
           data-aos="fade-up" 
           data-aos-duration="1000">
        <form id="waitlist-form" class="space-y-6">
          <h2 class="text-3xl font-bold text-center text-white mb-6">Join the waitlist today</h2>
          <div class="flex flex-col sm:flex-row gap-4">
            <input
              name="Email"
              type="email"
              placeholder="Enter your email address"
              required
              class="flex-1 px-6 py-4 bg-gray-800 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
            />
            <button 
              type="submit"
              class="px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-lg transition-colors duration-200"
            >
              Join Now!
            </button>
          </div>
          <div class="waitlist-messages hidden text-center text-green-400 font-semibold bg-green-900 bg-opacity-20 border border-green-800 rounded-lg py-3">
            Thank you for joining our waitlist!
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Problems & Solutions Section -->
<section id="intention" class="wrapper bg-gray-900 py-20">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Problems -->
      <section data-aos="fade-right" data-aos-duration="800">
        <div class="h-full bg-gray-950 rounded-xl border border-red-900 p-8">
          <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-red-900 bg-opacity-20 rounded-lg flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
              </svg>
            </div>
            <h2 class="text-3xl font-bold text-white">Problems</h2>
          </div>
          <ul class="space-y-4 text-gray-300">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-red-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              <span>People want to have the security confidence and control over who can access their data and why</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-red-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              <span>Centralized network providers could be a single point of failure if they are compromised by bad actors</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-red-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              <span>Centralized network providers are often closed-source with a false sense of security</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-red-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              <span>Existing decentralized solutions require Hosts to earn in their company's cryptocurrency</span>
            </li>
          </ul>
        </div>
      </section>

      <!-- Solutions -->
      <section data-aos="fade-left" data-aos-duration="800">
        <div class="h-full bg-gray-950 rounded-xl border border-green-900 p-8">
          <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-green-900 bg-opacity-20 rounded-lg flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h2 class="text-3xl font-bold text-white">Solutions</h2>
          </div>
          <ul class="space-y-4 text-gray-300">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Anyone with internet access can be our Partner as a Node Host and earn in their preferred currency</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Each node operates independently to compartmentalize information through our network</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>We are completely open-sourced, allowing anyone to inspect and provide feedback to improve our security, UX, and infrastructure</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-green-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Multiple independent nodes allows us to have competitive pricing without compromising quality</span>
            </li>
          </ul>
          <div class="mt-6">
            <a 
              href="/about" 
              class="inline-flex items-center text-primary-400 hover:text-primary-300 font-semibold"
            >
              Learn more
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>
    </div>
  </div>
</section>

<!-- Team Section -->
<section id="team" class="wrapper bg-gray-950 py-20">
  <div class="inner">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="text-center mb-16" data-aos="fade-up">
        <h1 class="text-5xl font-bold text-white mb-4">
          About Us
        </h1>
        <div class="w-24 h-1 bg-primary-500 mx-auto mb-8"></div>
      </div>
      
      <div
        class="bg-gray-900 rounded-xl border border-gray-800 p-8 md:p-12 mb-12"
        data-aos="fade-up"
        data-aos-duration="800"
      >
        <p class="text-lg md:text-xl text-gray-300 leading-relaxed text-center">
          Our team is made up of product leaders, engineers, and developers
          from <span class="font-semibold text-primary-400">Palantir</span>, <span class="font-semibold text-primary-400">French Military</span>, and <span class="font-semibold text-primary-400">Akamai Technologies</span>.
          We have a track-record of creating mission-critical decentralized
          security products for mission-critical organizations and we have the
          partnerships and resources to help you build your own decentralized
          network.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Team Member 1 -->
        <div
          class="bg-gray-900 rounded-xl border border-gray-800 p-6 hover:border-primary-500 transition-colors duration-200"
          data-aos="fade-up"
          data-aos-duration="800"
        >
          <div class="flex flex-col items-center text-center">
            <img
              class="grayscale hover:grayscale-0 h-32 w-32 rounded-full ring-2 ring-gray-700 mb-4 transition-all duration-200"
              src={Ting.src}
              alt="Ting Lik To"
            />
            <h3 class="text-2xl font-bold text-white mb-2">Ting Lik To</h3>
            <p class="text-primary-400 font-semibold mb-4">CEO</p>
            <div class="flex gap-4">
              <a
                href="https://www.linkedin.com/in/tinglik/"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 bg-gray-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors duration-200"
              >
                <i class="fab fa-linkedin text-xl"></i>
              </a>
              <a
                href="https://www.linkedin.com/in/tinglik/"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 bg-gray-800 hover:bg-gray-700 rounded-lg flex items-center justify-center transition-colors duration-200"
              >
                <i class="fab fa-github text-xl"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- Team Member 2 -->
        <div
          class="bg-gray-900 rounded-xl border border-gray-800 p-6 hover:border-primary-500 transition-colors duration-200"
          data-aos="fade-up"
          data-aos-duration="1000"
        >
          <div class="flex flex-col items-center text-center">
            <img
              class="grayscale hover:grayscale-0 h-32 w-32 rounded-full ring-2 ring-gray-700 mb-4 transition-all duration-200"
              src={Groot.src}
              alt="Groot"
            />
            <h3 class="text-2xl font-bold text-white mb-2">Groot</h3>
            <p class="text-primary-400 font-semibold mb-4">CTO</p>
            <div class="flex gap-4">
              <a
                href="https://x.com/rootshe11"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 bg-gray-800 hover:bg-blue-500 rounded-lg flex items-center justify-center transition-colors duration-200"
              >
                <i class="fab fa-twitter text-xl"></i>
              </a>
              <a
                href="https://github.com/smolgroot"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 bg-gray-800 hover:bg-gray-700 rounded-lg flex items-center justify-center transition-colors duration-200"
              >
                <i class="fab fa-github text-xl"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- Team Member 3 -->
        <div
          class="bg-gray-900 rounded-xl border border-gray-800 p-6 hover:border-primary-500 transition-colors duration-200"
          data-aos="fade-up"
          data-aos-duration="1200"
        >
          <div class="flex flex-col items-center text-center">
            <img
              class="grayscale hover:grayscale-0 h-32 w-32 rounded-full ring-2 ring-gray-700 mb-4 transition-all duration-200"
              src={Megan.src}
              alt="Megan Drown"
            />
            <h3 class="text-2xl font-bold text-white mb-2">Megan Drown</h3>
            <p class="text-primary-400 font-semibold mb-4">Product / Business Development</p>
            <div class="flex gap-4">
              <a
                href="https://www.linkedin.com/in/megan-drown/"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 bg-gray-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors duration-200"
              >
                <i class="fab fa-linkedin text-xl"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <script>
    import { aosInit } from "@js/aos";

    // runs on initial page load
    aosInit();
  </script>
  
  <script>
    document
      .getElementById("waitlist-form")
      ?.addEventListener("submit", function (event) {
        event.preventDefault();
        const form = event.target as HTMLFormElement;
        const formData = new FormData(form);

        fetch(
          "https://script.google.com/macros/s/AKfycbxgowDv4E0Kqqkex4FjL78XK6DIpRE_6emhaOcs1zQJ_MGDC0mXIKmW_BwA4tH-oswK/exec",
          {
            method: "POST",
            body: formData,
          }
        )
          .then((response) => response.json())
          .then((data) => {
            form.reset();
            const messageElement = document.querySelector(".waitlist-messages");
            if (messageElement) {
              messageElement.classList.remove("hidden");
            }
          })
          .catch((error) => {
            console.error("Error:", error);
          });
      });
  </script>
</section>
