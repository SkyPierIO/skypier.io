---
import "@style/App.css"
import Logo from "@svg/logo.svg"
---

<style>
    #modern-footer {
        background: rgba(0, 0, 0, 0.75); /* Same as header - dark with transparency */
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-top: 1px solid rgba(14, 165, 233, 0.1); /* Matching header border */
    }

    #modern-footer .footer-logo {
        height: 48px;
        width: auto;
        filter: brightness(0) invert(1); /* Makes the logo white */
    }

    #modern-footer h4 {
        color: #0ea5e9; /* primary-500 */
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
    }

    #modern-footer p, #modern-footer a {
        color: rgba(255, 255, 255, 0.85); /* Matching header text opacity */
        font-size: 0.875rem;
        transition: color 0.2s ease;
    }

    #modern-footer a:hover {
        color: #0ea5e9; /* primary-500 */
    }

    #modern-footer .social-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(14, 165, 233, 0.1);
        border: 1px solid rgba(14, 165, 233, 0.3);
        border-radius: 0.5rem;
        transition: all 0.2s ease;
    }

    #modern-footer .social-icon:hover {
        background: rgba(14, 165, 233, 0.2);
        border-color: #0ea5e9;
        transform: translateY(-2px);
    }

    #modern-footer .copyright {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.875rem;
    }

    #modern-footer .disabled-link {
        opacity: 0.5;
        cursor: not-allowed;
        pointer-events: none;
    }
</style>

<!-- Footer -->
<footer id="modern-footer" class="wrapper">
    <div class="container mx-auto px-6 py-12">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
            <!-- Skypier elements section -->
            <div>
                <div class="mb-4 flex items-center justify-center md:justify-start">
                    <img
                        src={Logo.src}
                        class="footer-logo"
                        alt="Skypier logo"
                    />
                </div>
                <p class="text-center md:text-left">
                    Empowering digital freedom through decentralized privacy solutions.
                </p>
            </div>

            <!-- Products section -->
            <div>
                <h4 class="text-center md:text-left">PRODUCTS</h4>
                <div class="space-y-3">
                    <p class="flex items-center justify-center md:justify-start">
                        <a 
                            href="https://tinglik.notion.site/On-boarding-the-SkyPier-Network-0967d277dfee49dfb2e537a1b89961b6" 
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            Skypier VPN
                        </a>
                    </p>
                    <p class="flex items-center justify-center md:justify-start">
                        <span class="disabled-link">More to come...</span>
                    </p>
                </div>
            </div>

            <!-- Useful links section -->
            <div>
                <h4 class="text-center md:text-left">RESOURCES</h4>
                <div class="space-y-3">
                    <p class="flex items-center justify-center md:justify-start">
                        <a href="/terms-of-service">Terms of Service</a>
                    </p>
                    <p class="flex items-center justify-center md:justify-start">
                        <a href="/privacy-policy">Privacy Policy</a>
                    </p>
                    <p class="flex items-center justify-center md:justify-start">
                        <a 
                            href="https://tinglik.notion.site/On-boarding-the-SkyPier-Network-0967d277dfee49dfb2e537a1b89961b6"
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            Documentation
                        </a>
                    </p>
                </div>
            </div>

            <!-- Contact section -->
            <div>
                <h4 class="text-center md:text-left">CONTACT</h4>
                <div class="space-y-3">
                    <p class="flex items-center justify-center md:justify-start">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="mr-3 h-5 w-5 flex-shrink-0">
                            <path
                                d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z" />
                            <path
                                d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z" />
                        </svg>
                        <span>New York, NY 10012, US</span>
                    </p>
                    <p class="flex items-center justify-center md:justify-start">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="mr-3 h-5 w-5 flex-shrink-0">
                            <path
                                d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
                            <path
                                d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
                        </svg>
                        <a href="mailto:info@skypier.io">info@skypier.io</a>
                    </p>
                    <div class="flex gap-3 justify-center md:justify-start pt-2">
                        <a 
                            class="social-icon" 
                            href="https://twitter.com/SkypierIO" 
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Twitter"
                        >
                            <i class="fab fa-lg fa-twitter"></i>
                        </a>
                        <a 
                            class="social-icon" 
                            href="https://github.com/SkyPierIO" 
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="GitHub"
                        >
                            <i class="fab fa-lg fa-github"></i>
                        </a>
                        <a 
                            class="social-icon" 
                            href="https://www.linkedin.com/company/Skypier" 
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="LinkedIn"
                        >
                            <i class="fab fa-lg fa-linkedin"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Copyright section -->
    <div class="copyright p-6 text-center">
        <span>© 2025 Skypier Technologies. All rights reserved.</span>
    </div>
</footer>