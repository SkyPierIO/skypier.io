---
// Component imports
import { Layout } from "@globals"
import "@style/css/main.css";
import "@style/css/noscript.css";
import "aos/dist/aos.css";

const title = 'Products - Skypier Technologies';
const description = 'Explore Skypier\'s privacy-focused products including our decentralized VPN solution.';
---

<Layout {title} {description}>
  <!-- Hero Section -->
  <section class="wrapper py-32 bg-gray-950">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="text-center mb-16" data-aos="fade-up" data-aos-duration="800">
        <h1 class="text-5xl md:text-7xl font-bold text-white leading-tight mb-6">
          Our Products
        </h1>
        <p class="text-xl md:text-2xl text-gray-400 max-w-3xl mx-auto">
          Privacy-focused solutions for the decentralized web
        </p>
        <div class="w-24 h-1 bg-primary-500 mx-auto mt-8"></div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section class="wrapper py-20 bg-gray-900">
    <div class="container mx-auto px-4 max-w-7xl">
      <!-- Skypier VPN -->
      <div 
        class="bg-gray-950 rounded-xl border border-gray-800 overflow-hidden"
        data-aos="fade-up"
        data-aos-duration="800"
      >
        <div class="grid md:grid-cols-2 gap-0">
          <!-- Product Image/Visual -->
          <div class="bg-gray-900 p-12 flex items-center justify-center">
            <div class="w-64 h-64 bg-primary-900 bg-opacity-20 rounded-xl flex items-center justify-center border border-primary-800">
              <svg class="w-32 h-32 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
            </div>
          </div>

          <!-- Product Content -->
          <div class="p-8 md:p-12 flex flex-col justify-center">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-900 bg-opacity-20 border border-green-800 rounded-full w-fit mb-6">
              <span class="w-2 h-2 bg-green-500 rounded-full"></span>
              <span class="text-green-400 font-semibold text-sm">Available Now</span>
            </div>

            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
              Skypier VPN
            </h2>
            
            <p class="text-xl text-gray-300 mb-8 leading-relaxed">
              A decentralized, peer-to-peer VPN built for privacy and security. Protect your digital identity while supporting the network economy.
            </p>

            <!-- Features Grid -->
            <div class="grid sm:grid-cols-2 gap-4 mb-8">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-green-900 bg-opacity-20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">Decentralized Network</h3>
                  <p class="text-gray-400 text-sm">No single point of failure</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-green-900 bg-opacity-20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">Token Gated</h3>
                  <p class="text-gray-400 text-sm">Secure access control</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-green-900 bg-opacity-20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">Open Source</h3>
                  <p class="text-gray-400 text-sm">Transparent & auditable</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-green-900 bg-opacity-20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">Peer-to-Peer</h3>
                  <p class="text-gray-400 text-sm">Direct connections</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-green-900 bg-opacity-20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">Privacy First</h3>
                  <p class="text-gray-400 text-sm">No logging, no tracking</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-green-900 bg-opacity-20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-white font-semibold mb-1">Earn as You Host</h3>
                  <p class="text-gray-400 text-sm">Monetize your bandwidth</p>
                </div>
              </div>
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4">
              <a
                href="https://tinglik.notion.site/On-boarding-the-SkyPier-Network-0967d277dfee49dfb2e537a1b89961b6"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-lg transition-colors duration-200"
              >
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
                Get Started
              </a>
              <a
                href="#contact"
                class="inline-flex items-center px-8 py-4 bg-gray-800 hover:bg-gray-700 text-white font-semibold rounded-lg border border-gray-700 transition-colors duration-200"
              >
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                </svg>
                Contact Sales
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Technical Details -->
      <div 
        class="mt-12 bg-gray-950 rounded-xl border border-gray-800 p-8 md:p-12"
        data-aos="fade-up"
        data-aos-duration="1000"
      >
        <h3 class="text-3xl font-bold text-white mb-6">How It Works</h3>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-primary-900 bg-opacity-20 border border-primary-800 rounded-xl flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl font-bold text-primary-500">1</span>
            </div>
            <h4 class="text-xl font-semibold text-white mb-3">Connect</h4>
            <p class="text-gray-400">
              Download the Skypier VPN client and authenticate using your token-gated access.
            </p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-primary-900 bg-opacity-20 border border-primary-800 rounded-xl flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl font-bold text-primary-500">2</span>
            </div>
            <h4 class="text-xl font-semibold text-white mb-3">Route</h4>
            <p class="text-gray-400">
              Your traffic is encrypted and routed through our decentralized network of nodes.
            </p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-primary-900 bg-opacity-20 border border-primary-800 rounded-xl flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl font-bold text-primary-500">3</span>
            </div>
            <h4 class="text-xl font-semibold text-white mb-3">Browse</h4>
            <p class="text-gray-400">
              Enjoy private, secure browsing with complete anonymity and no logging.
            </p>
          </div>
        </div>
      </div>

      <!-- Coming Soon Section -->
      <div 
        class="mt-12 bg-gray-950 rounded-xl border border-gray-800 p-8 md:p-12 text-center"
        data-aos="fade-up"
        data-aos-duration="1200"
      >
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gray-800 border border-gray-700 rounded-full mb-6">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span class="text-gray-400 font-semibold text-sm">Coming Soon</span>
        </div>
        <h3 class="text-3xl font-bold text-white mb-4">More Products in Development</h3>
        <p class="text-xl text-gray-400 max-w-3xl mx-auto mb-8">
          We're working on expanding our privacy stack with additional decentralized solutions. Join our waitlist to be the first to know about new product launches.
        </p>
        <a 
          href="/#intro"
          class="inline-flex items-center px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-lg transition-colors duration-200"
        >
          Join Waitlist
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <script>
    import { aosInit } from "@js/aos";
    aosInit();
  </script>
</Layout>
